          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/004_rei.mp3"
    },
    {
      "name": "カレン",
      "text": "こんなとこで会うと思わなかった",
