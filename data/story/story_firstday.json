        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/020_karen.mp3"
    },
    {
      "name": "レイ",
      "text": "下じゃ会わないから",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/021_rei.mp3"
    }
  ]
