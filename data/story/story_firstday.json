        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/005_karen.mp3"
    },
    {
      "name": "レイ",
      "text": "まだ、ここにいるんだ",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/006_rei.mp3"
    },
    {
      "name": "カレン",
      "text": "仕事だからね。あんたは？",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/007_karen.mp3"
    },
    {
      "name": "レイ",
      "text": "これから働く",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/008_rei.mp3"
    },
    {
      "name": "カレン",
      "text": "向いてないと思うけど",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/009_karen.mp3"
    },
    {
      "name": "レイ",
      "text": "昔からそればっか",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/010_rei.mp3"
    },
    {
      "name": "カレン",
      "text": "ここ、遊びじゃないよ",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/011_karen.mp3"
    },
    {
      "name": "レイ",
      "text": "知ってる",
