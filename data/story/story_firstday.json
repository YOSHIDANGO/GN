        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/002_rei.mp3"
    },
    {
      "name": "カレン",
      "text": "……レイ？",
