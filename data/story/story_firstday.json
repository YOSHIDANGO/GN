        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/013_rei.mp3"
    },
    {
      "name": "カレン",
      "text": "……本気？",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/014_karen.mp3"
    },
    {
      "name": "レイ",
      "text": "あんたが一番なんでしょ",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/015_rei.mp3"
    },
    {
      "name": "カレン",
      "text": "そうだけど",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/016_karen.mp3"
    },
    {
      "name": "レイ",
      "text": "じゃあ、その席どかせるわ",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/017_rei.mp3"
    },
    {
      "name": "カレン",
      "text": "無理。あんたには",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/018_karen.mp3"
    },
    {
      "name": "レイ",
      "text": "決めるの早くない？",
      "chars": [
        {
          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/019_rei.mp3"
    },
    {
      "name": "カレン",
      "text": "下で会ったら、ちゃんと挨拶しな",
