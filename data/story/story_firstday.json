          "key": "rei_normal",
          "x": 360,
          "scale": 0.5
        },
        {
          "key": "karen_normal",
          "x": 920,
          "scale": 0.5
        }
      ],
      "voice": "./assets/audio/voice/story/story_firstday/003_karen.mp3"
    },
    {
      "name": "レイ",
      "text": "……は？",
